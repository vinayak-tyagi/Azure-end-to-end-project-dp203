{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "staging_customers_conn",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "AzureBlobStorage1",
						"type": "LinkedServiceReference"
					},
					"name": "maleSink",
					"rejectedDataLinkedService": {
						"referenceName": "AzureBlobStorage1",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "split1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          customer_id as string,",
				"          country as string,",
				"          age as string,",
				"          gender as string,",
				"          membership_tier as string,",
				"          registration_date as string,",
				"          total_orders as string,",
				"          total_spend_usd as string,",
				"          avg_order_value_usd as string,",
				"          days_since_last_purchase as string,",
				"          preferred_category as string,",
				"          preferred_device as string,",
				"          preferred_payment_method as string,",
				"          acquisition_channel as string,",
				"          reviews_given as string,",
				"          avg_review_score as string,",
				"          returns_made as string,",
				"          wishlist_items as string,",
				"          newsletter_subscribed as string,",
				"          churned as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 split(gender == 'male',",
				"     gender == 'female',",
				"     disjoint: true) ~> split1@(male, female, others)",
				"split1@male sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delimited',",
				"     container: 'processed',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     quoteAll: true,",
				"     outputAssertFailedRows: true,",
				"     assertFailure_container: 'curated') ~> maleSink"
			]
		}
	}
}